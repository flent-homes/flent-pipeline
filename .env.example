# Option A — path to JSON key file (recommended locally). File must be gitignored.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=supply-fde-d60d5c58f840.json

# Option B — inline JSON (one line) instead of KEY_PATH
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheets API enabled on the GCP project. Share the sheet with the service account email.
# From the sheet URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SPREADSHEET_ID=

# Full SupplyDump tab (all rows, columns A–ZZ). Widen if you add columns past ZZ.
GOOGLE_SHEET_RANGE=SupplyDump!A:ZZ

# --- Optional: Vertex AI (see INTEGRATIONS.md) ---
# GOOGLE_CLOUD_PROJECT=supply-fde
# VERTEX_LOCATION=us-central1
# VERTEX_GEMINI_MODEL=gemini-2.0-flash-001

# --- Optional: Slack Incoming Webhook ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Optional: OpenAI scoring (preferred if key present) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1

# --- Optional: Gemini key-based scoring (AI Studio) ---
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL_NAME=gemini-2.5-pro
